# ══════════════════════════════════════════════════════════════
#  VETRAJ PET HOSPITAL — Environment Variables
#  Copy this file to .env and fill in your values
#  Command: cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── SERVER ──────────────────────────────────────────────────
PORT=3000
BASE_URL=https://yourdomain.com

# ── ADMIN PANEL PASSWORD ─────────────────────────────────────
# Dashboard aur Telecaller panel ka password
# Default: vetraj2024 (CHANGE IN PRODUCTION!)
ADMIN_KEY=vetraj2024

# ── CLAUDE AI (Anthropic) ────────────────────────────────────
# Pet health chat ke liye AI — Required hai
# Get from: https://console.anthropic.com → API Keys
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MONGODB ATLAS ────────────────────────────────────────────
# Production database — Agar nahi diya to file-based storage use hoga
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
# Format: mongodb+srv://username:password@cluster.mongodb.net/vetraj
MONGODB_URI=mongodb+srv://vetrajuser:PASSWORD@cluster0.xxxxx.mongodb.net/vetraj?retryWrites=true&w=majority

# ── AKASHVANNI WHATSAPP API ──────────────────────────────────
# OTP aur PDF report WhatsApp pe bhejna
# Get from: https://app.akashvanni.com → Profile → User ID
# Templates needed: otp_verification, health_report
AKASHVANNI_USER_ID=your_akashvanni_user_id_here

# ── RAZORPAY PAYMENT GATEWAY ─────────────────────────────────
# ₹399 consultation payment ke liye
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WHATSAPP BUSINESS API (Meta) ─────────────────────────────
# Webhook verify token — aap khud koi bhi string rakh sakte ho
# Meta Developer Console mein same token daalna hoga
WA_VERIFY_TOKEN=vetraj_webhook_2024
